<section id="contact" class="py-24 border-t border-slate-800">
  <div class="max-w-5xl mx-auto px-6 text-center">
    <p class="font-mono text-cyan-400 text-xs mb-2 tracking-widest uppercase">04. Contact</p>
    <h2 class="text-3xl font-bold text-slate-100 mb-6">Get in touch</h2>
    <p class="text-slate-400 mb-10 max-w-md mx-auto leading-relaxed">
      Open to Platform Engineering, DevOps, and SRE roles. Feel free to reach out.
    </p>
    <div class="flex gap-4 justify-center flex-wrap">
      <a
        href="mailto:YOUR_EMAIL"
        class="px-6 py-3 rounded-lg border border-cyan-400 text-cyan-400 hover:bg-cyan-400 hover:text-slate-950 font-medium transition-colors"
      >
        Send an email
      </a>
      <a
        href="https://linkedin.com/in/YOUR_LINKEDIN_USERNAME"
        target="_blank"
        rel="noopener noreferrer"
        class="px-6 py-3 rounded-lg border border-slate-700 text-slate-300 hover:border-slate-500 hover:text-slate-100 font-medium transition-colors"
      >
        LinkedIn
      </a>
    </div>
  </div>
</section>

<footer class="border-t border-slate-800 py-8 text-center text-slate-600 text-xs font-mono">
  Built with Astro · Self-hosted on homelab
</footer>
