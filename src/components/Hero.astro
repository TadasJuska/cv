---
const links = [
  { label: 'GitHub', href: 'https://github.com/TadasJuska' },
  { label: 'LinkedIn', href: 'https://linkedin.com/in/YOUR_LINKEDIN_USERNAME' },
];
---
<section class="min-h-screen flex items-center pt-14">
  <div class="max-w-5xl mx-auto px-6 py-24">
    <p class="font-mono text-cyan-400 text-sm mb-4 tracking-widest uppercase">Hi, I'm</p>
    <h1 class="text-7xl font-bold text-slate-100 mb-3 tracking-tight">Tadas</h1>
    <h2 class="text-3xl font-medium text-slate-400 mb-8">Platform Engineer</h2>
    <p class="text-lg text-slate-400 max-w-2xl mb-10 leading-relaxed">
      I design and build scalable infrastructure, internal developer platforms, and the automation
      that lets engineering teams ship with confidence. I care about observability, security, and
      treating infrastructure as a first-class product.
    </p>
    <div class="flex gap-4 flex-wrap">
      {links.map(({ label, href }) => (
        <a
          href={href}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 px-5 py-2.5 rounded-lg bg-slate-900 hover:bg-slate-800 text-slate-200 text-sm font-medium transition-colors border border-slate-700 hover:border-slate-600"
        >
          {label}
        </a>
      ))}
      <a
        href="#contact"
        class="inline-flex items-center gap-2 px-5 py-2.5 rounded-lg border border-cyan-400 text-cyan-400 hover:bg-cyan-400 hover:text-slate-950 text-sm font-medium transition-colors"
      >
        Get in touch
      </a>
    </div>
  </div>
</section>
