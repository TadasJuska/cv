---
const projects = [
  {
    name: 'Homelab (beenas)',
    description:
      'Production-grade self-hosted infrastructure running 15+ services on Docker Compose. Traefik reverse proxy with automatic wildcard TLS via DuckDNS, WireGuard VPN, Gatus uptime monitoring with Discord alerting, network-edge IP blocking via banip, and nightly encrypted backups with 7-day retention.',
    tech: ['Docker Compose', 'Traefik', 'WireGuard', 'Gatus', "Let's Encrypt", 'nginx'],
    url: 'https://github.com/TadasJuska/beenas',
  },
  // Add more projects here
];
---
<section id="projects" class="py-24 border-t border-slate-800">
  <div class="max-w-5xl mx-auto px-6">
    <p class="font-mono text-cyan-400 text-xs mb-2 tracking-widest uppercase">03. Projects</p>
    <h2 class="text-3xl font-bold text-slate-100 mb-12">Things I've built</h2>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
      {projects.map(project => (
        <a
          href={project.url}
          target="_blank"
          rel="noopener noreferrer"
          class="group bg-slate-900 rounded-xl border border-slate-800 p-6 hover:border-cyan-400/40 transition-colors flex flex-col gap-4"
        >
          <div class="flex items-start justify-between gap-4">
            <h3 class="text-slate-100 font-semibold group-hover:text-cyan-400 transition-colors">
              {project.name}
            </h3>
            <span class="text-slate-500 group-hover:text-slate-300 transition-colors text-lg leading-none shrink-0">
              ↗
            </span>
          </div>
          <p class="text-slate-400 text-sm leading-relaxed flex-1">{project.description}</p>
          <div class="flex flex-wrap gap-2">
            {project.tech.map(t => (
              <span class="px-2 py-0.5 rounded text-xs font-mono bg-slate-800 text-slate-400 border border-slate-700">
                {t}
              </span>
            ))}
          </div>
        </a>
      ))}
    </div>
  </div>
</section>
