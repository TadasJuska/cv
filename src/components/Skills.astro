---
const skills = [
  {
    category: 'Cloud & IaC',
    items: ['AWS', 'Terraform', 'Pulumi', 'Ansible', 'CloudFormation'],
  },
  {
    category: 'Containers & Orchestration',
    items: ['Docker', 'Kubernetes', 'Helm', 'k3s', 'Docker Compose'],
  },
  {
    category: 'CI/CD & GitOps',
    items: ['GitHub Actions', 'ArgoCD', 'Flux', 'GitLab CI', 'Jenkins'],
  },
  {
    category: 'Observability',
    items: ['Prometheus', 'Grafana', 'Loki', 'OpenTelemetry', 'ELK Stack'],
  },
  {
    category: 'Networking & Security',
    items: ['Traefik', 'nginx', 'WireGuard', 'Cloudflare', 'Vault'],
  },
  {
    category: 'Languages',
    items: ['Python', 'Go', 'Bash', 'TypeScript', 'YAML'],
  },
];
---
<section id="skills" class="py-24 border-t border-slate-800">
  <div class="max-w-5xl mx-auto px-6">
    <p class="font-mono text-cyan-400 text-xs mb-2 tracking-widest uppercase">01. Skills</p>
    <h2 class="text-3xl font-bold text-slate-100 mb-12">What I work with</h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
      {skills.map(({ category, items }) => (
        <div class="bg-slate-900 rounded-xl border border-slate-800 p-6 hover:border-slate-700 transition-colors">
          <h3 class="text-slate-300 font-semibold mb-4 text-xs uppercase tracking-widest">
            {category}
          </h3>
          <div class="flex flex-wrap gap-2">
            {items.map(item => (
              <span class="px-3 py-1 rounded-full text-xs font-mono bg-slate-800 text-slate-300 border border-slate-700">
                {item}
              </span>
            ))}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
