---
interface Props {
  title?: string;
  description?: string;
}
const {
  title = 'Tadas Juška — Platform & DevOps Engineer',
  description = 'Platform & DevOps Engineer available for contracts. Building scalable infrastructure, CI/CD pipelines, and developer platforms.',
} = Astro.props;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="description" content={description} />
    <title>{title}</title>
  </head>
  <body class="bg-slate-950 antialiased">
    <slot />
  </body>
</html>
