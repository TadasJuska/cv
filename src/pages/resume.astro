---
import { hero, skills, experience, certifications, education } from '../data/cv';

// Condensed, one-page view of the experience data (most recent first, trimmed bullets)
const roles = [
  {
    title: 'Platform Engineer · Contract',
    org: 'Wise',
    location: 'Iceland',
    period: 'Aug 2023 – Jul 2026',
    bullets: experience[0].clients[0].bullets.slice(0, 4),
  },
  {
    title: 'Senior Infrastructure Engineer',
    org: 'Swedbank',
    location: 'Sweden',
    period: 'Apr 2018 – Aug 2023',
    bullets: experience[1].clients[0].bullets.slice(0, 3),
  },
  {
    title: 'Senior System Administrator',
    org: 'Rubineta',
    location: 'Lithuania',
    period: 'May 2015 – Apr 2018',
    bullets: experience[2].clients[0].bullets.slice(0, 1),
  },
];

const fullName = `${hero.firstName} ${hero.lastName}`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{fullName} — {hero.title}</title>
    <meta name="description" content={`${fullName} — ${hero.title}. One-page CV.`} />
  </head>
  <body>
    <button class="no-print print-btn" onclick="window.print()">Save as PDF</button>

    <main class="page">
      <header class="head">
        <div>
          <h1>{fullName}</h1>
          <p class="role">{hero.title}</p>
        </div>
        <div class="contact">
          <span>{hero.email}</span>
          <span>{hero.siteUrl}</span>
          <span>{hero.githubShort}</span>
          <span>linkedin.com/in/tadasjuska</span>
          <span>{hero.location}</span>
          <span>{hero.languages}</span>
        </div>
      </header>

      <p class="summary">{hero.bio}</p>

      <div class="grid">
        <section class="main">
          <h2>Experience</h2>
          {roles.map(r => (
            <article class="entry">
              <div class="entry-head">
                <span class="entry-title">{r.title} · <span class="org">{r.org}</span></span>
                <span class="period">{r.period}</span>
              </div>
              <p class="loc">{r.location}</p>
              <ul>
                {r.bullets.map(b => <li>{b}</li>)}
              </ul>
            </article>
          ))}
        </section>

        <aside class="side">
          <h2>Skills</h2>
          <ul class="skills">
            {skills.map(group => (
              <li><span class="cat">{group.category}</span>{group.items.join(' · ')}</li>
            ))}
          </ul>

          <h2>Certifications</h2>
          <ul class="certs">
            {certifications.map(c => (
              <li><span class="cert-name">{c.name}</span><span class="cert-meta">{c.issuer} · {c.issued}</span></li>
            ))}
          </ul>

          <h2>Education</h2>
          {education.map(e => (
            <div class="edu">
              <span class="edu-degree">{e.degree}</span>
              <span class="cert-meta">{e.institution} · {e.period}</span>
            </div>
          ))}
        </aside>
      </div>
    </main>

    <style>
      :root {
        --ink: #1e293b;
        --muted: #64748b;
        --accent: #0891b2;
        --line: #e2e8f0;
      }
      * { box-sizing: border-box; }
      html, body {
        margin: 0;
        background: #f1f5f9;
        color: var(--ink);
        font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
        font-size: 10.5px;
        line-height: 1.45;
      }
      .page {
        max-width: 210mm;
        min-height: 297mm;
        margin: 1.5rem auto;
        background: #fff;
        padding: 14mm 14mm 12mm;
        box-shadow: 0 4px 24px rgba(15, 23, 42, 0.12);
      }
      .head {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        gap: 1.5rem;
        border-bottom: 2px solid var(--accent);
        padding-bottom: 0.6rem;
        margin-bottom: 0.6rem;
      }
      h1 {
        font-size: 24px;
        margin: 0;
        letter-spacing: -0.01em;
      }
      .role {
        margin: 0.1rem 0 0;
        color: var(--accent);
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.12em;
        font-size: 10px;
      }
      .contact {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 0.05rem 1rem;
        text-align: right;
        color: var(--muted);
        font-size: 9.5px;
      }
      .summary {
        margin: 0 0 0.8rem;
        color: #334155;
      }
      .grid {
        display: grid;
        grid-template-columns: 1.65fr 1fr;
        gap: 1.4rem;
      }
      h2 {
        font-size: 10px;
        text-transform: uppercase;
        letter-spacing: 0.14em;
        color: var(--accent);
        border-bottom: 1px solid var(--line);
        padding-bottom: 0.2rem;
        margin: 0 0 0.5rem;
      }
      .side h2 { margin-top: 0.9rem; }
      .side h2:first-child { margin-top: 0; }
      .entry { margin-bottom: 0.7rem; }
      .entry:last-child { margin-bottom: 0; }
      .entry-head {
        display: flex;
        justify-content: space-between;
        align-items: baseline;
        gap: 0.5rem;
      }
      .entry-title { font-weight: 600; font-size: 11.5px; }
      .org { color: var(--accent); }
      .period { color: var(--muted); font-size: 9.5px; white-space: nowrap; }
      .loc { margin: 0 0 0.25rem; color: var(--muted); font-size: 9.5px; }
      ul { margin: 0; padding-left: 1rem; }
      .main li { margin-bottom: 0.18rem; }
      .skills, .certs { list-style: none; padding: 0; }
      .skills li { margin-bottom: 0.3rem; }
      .cat {
        display: block;
        font-weight: 600;
        color: var(--ink);
        font-size: 9px;
        text-transform: uppercase;
        letter-spacing: 0.06em;
      }
      .skills li { color: var(--muted); }
      .certs li { margin-bottom: 0.3rem; }
      .cert-name { display: block; font-weight: 600; }
      .cert-meta { display: block; color: var(--muted); font-size: 9.5px; }
      .edu-degree { display: block; font-weight: 600; }
      .print-btn {
        position: fixed;
        top: 1rem;
        right: 1rem;
        background: var(--accent);
        color: #fff;
        border: none;
        border-radius: 8px;
        padding: 0.55rem 1rem;
        font: inherit;
        font-weight: 600;
        cursor: pointer;
        box-shadow: 0 2px 10px rgba(8, 145, 178, 0.35);
      }
      .print-btn:hover { background: #0e7490; }

      @page { size: A4; margin: 0; }
      @media print {
        html, body { background: #fff; font-size: 10px; }
        .no-print { display: none !important; }
        .page {
          margin: 0;
          box-shadow: none;
          max-width: none;
          min-height: auto;
          padding: 12mm 12mm 10mm;
        }
        .entry, article { break-inside: avoid; }
        h2 { break-after: avoid; }
        * { -webkit-print-color-adjust: exact; print-color-adjust: exact; }
      }
    </style>
  </body>
</html>
