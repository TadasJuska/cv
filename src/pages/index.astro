---
import Layout from '../layouts/Layout.astro';
import '../styles/global.css';

const hero = {
  title: 'Senior Platform Engineer',
  firstName: 'Tadas',
  lastName: 'Juška',
  bio: "Platform and DevOps engineer focused on production-grade, cloud-native infrastructure — secure, observable, and genuinely automated. Comfortable across any Kubernetes distribution or cloud provider. The platform changes; the engineering principles don't.",
  email: 'tadas.juska@outlook.com',
  github: 'https://github.com/TadasJuska',
  linkedin: 'https://www.linkedin.com/in/tadasjuska',
  location: 'Remote · Europe',
  languages: 'Lithuanian · English',
};

const skills = [
  { category: 'Cloud & IaC', items: ['AWS', 'Azure', 'GCP', 'Terraform', 'OpenTofu', 'Terragrunt', 'Pulumi', 'Ansible', 'SaltStack', 'Chef', 'Puppet'] },
  { category: 'Containers & Platform', items: ['Kubernetes', 'Cilium', 'Karpenter', 'Helm', 'Docker', 'Podman', 'containerd', 'k3s', 'OPA', 'Gatekeeper', 'cert-manager'] },
  { category: 'CI/CD & GitOps', items: ['ArgoCD', 'Kargo', 'Flux', 'GitHub Actions', 'GitLab CI', 'Jenkins', 'Tekton', 'Renovate'] },
  { category: 'Observability', items: ['Prometheus', 'Grafana', 'Loki', 'OpenTelemetry', 'Elasticsearch', 'Kibana', 'Zabbix', 'Icinga2'] },
  { category: 'Security & Networking', items: ['Cilium mTLS', 'SPIFFE/SPIRE', 'VPN', 'OpenBao', 'Vault', 'Traefik', 'Nginx', 'Envoy', 'Istio'] },
  { category: 'Data & Messaging', items: ['PostgreSQL', 'RabbitMQ', 'Kafka', 'Zookeeper', 'Apache Solr', 'Oracle DB', 'Elasticsearch'] },
  { category: 'Languages', items: ['Python', 'Go', 'Bash', 'HCL', 'YAML'] },
];

const experience = [
  {
    title: 'Platform Engineer',
    company: 'Self-Employed · Contract',
    period: 'Aug 2023 – Present',
    description: 'Building and operating modern cloud-native platforms — where CI/CD, GitOps, and zero-trust networking are done right.',
    clients: [
      {
        name: 'Wise',
        location: 'Iceland',
        period: ' June 2024 – Jul 2026',
        bullets: [
          'Modernised platform networking with eBPF-based Cilium CNI — replacing kube-proxy, enabling WireGuard + ztunnel end-to-end encryption, and bringing zero-trust ambient mesh to production Kubernetes.',
          'Migrated CI/CD from Jenkins to GitHub Actions and introduced GitOps with ArgoCD and Helm — every change versioned, auditable, and automatically reconciled.',
          'Managed infrastructure with OpenTofu and OS-level configuration with SaltStack across multi-tenant SaaS environments.',
          'Operated Django microservices, PostgreSQL, Apache Solr, and SSO integrations with full observability via Prometheus, Grafana, and Alertmanager.',
        ],
      },
      {
        name: 'Coredata',
        location: 'Iceland',
        period: 'Aug 2023 – June 2024 ',
        bullets: [
          'Managed and scaled cloud infrastructure on AWS — EC2 fleet management and configuration automation with SaltStack.',
          'Led software version upgrades and vulnerability remediation across the stack, reducing exposure and keeping dependencies current.',
          'Identified and resolved performance bottlenecks, improving system throughput and reliability across environments.',
          'Supported engineering teams with infrastructure tooling and incident response.',
        ],
      },
    ],
  },
  {
    title: 'Senior Infrastructure Engineer',
    company: 'Swedbank',
    location: 'Sweden',
    period: 'Jun 2020 – Aug 2023',
    bullets: [
      'Evolved infrastructure across internal data centres and cloud (AWS, Azure); led performance, penetration, and security audits.',
      'Automated provisioning and configuration with Terraform, Ansible, and Puppet; managed incident response and on-call rotation.',
      'Delivered observability with Zabbix and Grafana across Oracle, PostgreSQL, and Cassandra.',
    ],
  },
  {
    title: 'Infrastructure Engineer',
    company: 'Swedbank',
    location: 'Sweden',
    period: 'Apr 2018 – Jun 2020',
    bullets: [
      'Managed Linux and Windows server environments — patching, vulnerability remediation, and network security.',
      'Automated operational tasks with Python, Bash, Jenkins, and Azure Pipelines.',
      'Implemented authentication and encryption: TLS, LDAP, Kerberos, NTLM, SSO.',
    ],
  },
  {
    title: 'Senior System Administrator',
    company: 'Rubineta',
    location: 'Lithuania',
    period: 'Jan 2016 – Apr 2018',
    bullets: [
      'Managed IT department budget and supervised a team of two.',
      'Administered server environments: patching, security hardening, and disaster recovery.',
      'Installed and maintained applications across Linux and Windows servers.',
    ],
  },
];

const projects = [
  {
    name: 'This Website · CV',
    description: 'This site — an Astro CV with a production-grade DevOps pipeline behind it.',
    bullets: [
      'Three gated GitHub Actions jobs: check (npm ci + build), scan (Trivy — blocks on CRITICAL/HIGH CVEs), and publish (multi-arch amd64/arm64 Docker image pushed to ghcr.io).',
      'Publish only runs on main after both check and scan pass.',
      'Dependabot keeps all Actions versions current.',
    ],
    tech: ['Astro', 'Docker', 'GitHub Actions', 'Trivy', 'ghcr.io'],
    url: 'https://github.com/TadasJuska/cv',
  },
  {
    name: 'Fully Managed EKS Platform',
    description: 'Production EKS cluster built entirely as code — every component self-managed and reconciled from Git.',
    bullets: [
      'ArgoCD app-of-apps GitOps with ApplicationSet templates — scales Helm deployments across environments without duplication.',
      'Kargo chart promotion with per-PR preview environments and approval gates into stg and prod.',
      'Cilium CNI with pod-to-pod mTLS and SPIFFE/SVID identity — zero-trust encryption for all in-cluster traffic, no sidecars.',
      'Karpenter node autoscaling, OpenBao + ESO for secrets, cert-manager for TLS, external-dns for automatic Route53 management.',
    ],
    tech: ['EKS', 'Terraform', 'OpenTofu', 'ArgoCD', 'Kargo', 'Cilium', 'Karpenter', 'OpenBao', 'ESO', 'Helm', 'external-dns', 'Route53'],
    private: true,
    arch: true,
  },
  {
    name: 'Cilium',
    description: 'Contributing directly to the Cilium open-source project on end-to-end encryption.',
    bullets: [
      'Implementing the ztunnel ambient proxy model — zero-trust, sidecar-free mTLS for production Kubernetes.',
      'Removing sidecar overhead while maintaining full encryption and identity enforcement across all in-cluster traffic.',
    ],
    tech: ['Kubernetes', 'eBPF', 'Cilium', 'WireGuard', 'Zero Trust'],
    url: 'https://github.com/cilium/cilium',
  },
  {
    name: 'Homelab',
    description: 'Personal lab for running things I actually use.',
    bullets: [
      'Media server, home automation, and a custom OpenWrt router.',
      'Traefik handles routing and TLS across all services.',
      'k3s cluster running ArgoCD and Kargo — watches and promotes this CV into the homelab environment.',
      'Practical environment for testing infra patterns before applying them at work.',
    ],
    tech: ['Docker', 'Traefik', 'Home Assistant', 'OpenWrt', "Let's Encrypt"],
  },
];
---

<Layout>
  <!-- Scroll progress bar -->
  <div id="progress-bar" class="fixed top-0 left-0 h-0.5 bg-cyan-500 z-50 w-0 transition-none"></div>

  <!-- Print-only hero (static, no animations) -->
  <section class="print-only px-6 py-8 max-w-5xl mx-auto">
    <p style="color:#0891b2;font-family:monospace;font-size:0.75rem;text-transform:uppercase;letter-spacing:0.15em;margin-bottom:0.5rem">{hero.title}</p>
    <h1 style="font-size:2.5rem;font-weight:700;color:#0f172a;margin-bottom:1rem">{hero.firstName} <span style="color:#0891b2">{hero.lastName}</span></h1>
    <p style="color:#334155;font-size:0.95rem;line-height:1.7;max-width:42rem;margin-bottom:1rem">{hero.bio}</p>
    <p style="color:#64748b;font-size:0.8rem;font-family:monospace">
      {hero.email} &nbsp;·&nbsp; linkedin.com/in/tadasjuska &nbsp;·&nbsp; {hero.location} &nbsp;·&nbsp; {hero.languages}
    </p>
  </section>

  <!-- Hero -->
  <section class="no-print min-h-screen flex flex-col items-center justify-center relative px-6 text-center">
    <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_center,_rgba(6,182,212,0.08)_0%,_transparent_70%)]"></div>
    <p class="font-mono text-cyan-400 text-sm tracking-widest uppercase mb-8 opacity-0 animate-[charIn_0.6s_0.1s_cubic-bezier(0.16,1,0.3,1)_forwards]">
      {hero.title}
    </p>
    <h1 class="text-7xl md:text-9xl font-bold text-white tracking-tight mb-6 overflow-hidden">
      <span class="hero-char" style="animation-delay: 0.15s">T</span><span class="hero-char" style="animation-delay: 0.2s">a</span><span class="hero-char" style="animation-delay: 0.25s">d</span><span class="hero-char" style="animation-delay: 0.3s">a</span><span class="hero-char" style="animation-delay: 0.35s">s</span><span class="hero-char inline-block w-6" style="animation-delay: 0.4s"> </span><span class="hero-char text-cyan-400" style="animation-delay: 0.45s">J</span><span class="hero-char text-cyan-400" style="animation-delay: 0.5s">u</span><span class="hero-char text-cyan-400" style="animation-delay: 0.55s">š</span><span class="hero-char text-cyan-400" style="animation-delay: 0.6s">k</span><span class="hero-char text-cyan-400" style="animation-delay: 0.65s">a</span>
    </h1>
    <p class="text-slate-400 text-lg max-w-lg leading-relaxed opacity-0 animate-[charIn_0.6s_0.6s_cubic-bezier(0.16,1,0.3,1)_forwards]">
      {hero.bio}
    </p>
    <div class="flex gap-4 mt-10 opacity-0 animate-[charIn_0.6s_0.75s_cubic-bezier(0.16,1,0.3,1)_forwards] flex-wrap justify-center">
      <a href={`mailto:${hero.email}`}
        class="px-6 py-3 rounded-xl bg-cyan-600 hover:bg-cyan-500 text-white font-medium transition-colors">
        Email me
      </a>
      <a href={hero.github} target="_blank" rel="noopener noreferrer"
        class="px-6 py-3 rounded-xl bg-slate-800 hover:bg-slate-700 text-slate-200 font-medium transition-colors border border-slate-700">
        GitHub
      </a>
      <a href={hero.linkedin} target="_blank" rel="noopener noreferrer"
        class="px-6 py-3 rounded-xl bg-slate-800 hover:bg-slate-700 text-slate-200 font-medium transition-colors border border-slate-700">
        LinkedIn
      </a>
      <button
        id="download-pdf"
        title="Opens browser print dialog — choose 'Save as PDF'"
        class="no-print group flex items-center gap-2 px-6 py-3 rounded-xl bg-slate-800 hover:bg-slate-700 text-slate-200 font-medium transition-all border border-slate-700 hover:border-cyan-500/40 disabled:opacity-60 disabled:cursor-not-allowed"
      >
        <svg id="pdf-icon" xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M12 15V3m0 12-4-4m4 4 4-4"/>
          <path d="M2 17l.621 2.485A2 2 0 0 0 4.561 21h14.878a2 2 0 0 0 1.94-1.515L22 17"/>
        </svg>
        <svg id="pdf-spinner" xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 shrink-0 hidden animate-spin" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M21 12a9 9 0 1 1-6.219-8.56"/>
        </svg>
        <span id="pdf-btn-text">Save as PDF</span>
      </button>
    </div>
    <p class="flex items-center gap-1.5 mt-6 opacity-0 animate-[charIn_0.6s_0.9s_cubic-bezier(0.16,1,0.3,1)_forwards] text-slate-400 text-xs font-mono">
      <svg xmlns="http://www.w3.org/2000/svg" class="w-3 h-3" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"/></svg>
      {hero.location}
    </p>
    <p class="flex items-center gap-1.5 mt-2 opacity-0 animate-[charIn_0.6s_0.95s_cubic-bezier(0.16,1,0.3,1)_forwards] text-slate-400 text-xs font-mono">
      <svg xmlns="http://www.w3.org/2000/svg" class="w-3 h-3" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2a10 10 0 1 0 0 20A10 10 0 0 0 12 2zm-1 17.93V18a1 1 0 0 0-1-1H8v-2a1 1 0 0 1 1-1h2a1 1 0 0 0 1-1v-1a1 1 0 0 0-1-1h-1a1 1 0 0 1-1-1v-.5A1.5 1.5 0 0 0 7.5 9H7a1 1 0 0 1-1-1V7.07A8.003 8.003 0 0 1 11 4.07V5a1 1 0 0 0 1 1h.5A1.5 1.5 0 0 1 14 7.5v.5a1 1 0 0 0 1 1h.5a.5.5 0 0 1 .5.5v1a.5.5 0 0 1-.5.5H15a1 1 0 0 0-1 1v2a1 1 0 0 0 1 1 3 3 0 0 1 3 3v.17A8.003 8.003 0 0 1 11 19.93z"/></svg>
      {hero.languages}
    </p>
    <div class="absolute bottom-10 opacity-0 animate-[charIn_0.6s_1s_cubic-bezier(0.16,1,0.3,1)_forwards] flex flex-col items-center gap-2">
      <span class="text-slate-600 text-xs font-mono tracking-widest">SCROLL</span>
      <div class="w-px h-12 bg-gradient-to-b from-slate-600 to-transparent"></div>
    </div>
  </section>

  <!-- Skills -->
  <section class="py-32 px-6 max-w-5xl mx-auto">
    <div data-animate class="mb-16">
      <p class="font-mono text-cyan-400 text-xs tracking-widest uppercase mb-3">What I work with</p>
      <h2 class="text-4xl font-bold text-white">Skills</h2>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
      {skills.map((group, i) => (
        <div
          data-animate
          style={`transition-delay: ${i * 80}ms`}
          class="bg-slate-900 rounded-2xl border border-slate-800 p-6 hover:border-cyan-500/30 transition-colors"
        >
          <h3 class="text-slate-400 text-xs font-mono uppercase tracking-widest mb-4">{group.category}</h3>
          <div class="flex flex-wrap gap-2">
            {group.items.map(item => (
              <span class="px-3 py-1 rounded-full text-xs font-mono bg-slate-800 text-slate-400 border border-slate-700">
                {item}
              </span>
            ))}
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- Experience -->
  <section class="py-32 px-6 max-w-5xl mx-auto border-t border-slate-800/50">
    <div data-animate class="mb-16">
      <p class="font-mono text-cyan-400 text-xs tracking-widest uppercase mb-3">Where I've worked</p>
      <h2 class="text-4xl font-bold text-white">Experience</h2>
    </div>
    <div class="space-y-12">
      {experience.map((role, i) => (
        <div data-animate style={`transition-delay: ${i * 120}ms`} class="grid md:grid-cols-3 gap-6">
          <div class="md:col-span-1">
            <p class="font-mono text-slate-500 text-sm">{role.period}</p>
          </div>
          <div class="md:col-span-2 border-l-2 border-cyan-500/30 pl-6">
            <h3 class="text-white font-semibold text-xl mb-1">{role.title}</h3>
            <div class="flex items-center gap-3 mb-4 flex-wrap">
              <p class="text-cyan-400 text-sm font-semibold">{role.company}</p>
              {role.location && (
                <span class="flex items-center gap-1 text-slate-500 text-xs font-mono">
                  <svg xmlns="http://www.w3.org/2000/svg" class="w-3 h-3" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"/></svg>
                  {role.location}
                </span>
              )}
            </div>
            {role.description && (
              <p class="text-slate-400 text-sm leading-relaxed mb-6">{role.description}</p>
            )}
            {role.clients && (
              <div class="space-y-6">
                {role.clients.map(client => (
                  <div>
                    <p class="font-mono text-slate-500 text-xs mb-1">{client.period}</p>
                    <div class="flex items-center gap-3 mb-2 flex-wrap">
                      <span class="text-cyan-400 text-sm font-semibold">{client.name}</span>
                      {client.location && (
                        <span class="flex items-center gap-1 text-slate-500 text-xs font-mono">
                          <svg xmlns="http://www.w3.org/2000/svg" class="w-3 h-3" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"/></svg>
                          {client.location}
                        </span>
                      )}
                    </div>
                    <ul class="space-y-2.5">
                      {client.bullets.map(b => (
                        <li class="flex gap-3 text-slate-400 text-sm leading-relaxed">
                          <span class="w-1.5 h-1.5 rounded-full bg-cyan-400 shrink-0 mt-1.5 shadow-[0_0_6px_rgba(34,211,238,0.9)]"></span>{b}
                        </li>
                      ))}
                    </ul>
                  </div>
                ))}
              </div>
            )}
            {role.bullets && (
              <ul class="space-y-2.5">
                {role.bullets.map(b => (
                  <li class="flex gap-3 text-slate-400 text-sm leading-relaxed">
                    <span class="w-1.5 h-1.5 rounded-full bg-cyan-400 shrink-0 mt-1.5 shadow-[0_0_6px_rgba(34,211,238,0.9)]"></span>{b}
                  </li>
                ))}
              </ul>
            )}
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- Projects -->
  <section class="py-32 px-6 max-w-5xl mx-auto border-t border-slate-800/50">
    <div data-animate class="mb-16">
      <p class="font-mono text-cyan-400 text-xs tracking-widest uppercase mb-3">Things I've built</p>
      <h2 class="text-4xl font-bold text-white">Recent Projects</h2>
    </div>
    <div class="grid md:grid-cols-2 gap-6">
      {projects.map((project, i) => {
        const Tag = project.url ? 'a' : 'div';
        const linkProps = project.url ? { href: project.url, target: '_blank', rel: 'noopener noreferrer' } : {};
        return (
          <Tag
            {...linkProps}
            data-animate="scale"
            style={`transition-delay: ${i * 100}ms`}
            class={`group bg-slate-900 rounded-2xl border border-slate-800 p-8 transition-colors flex flex-col gap-4 ${project.url ? 'hover:border-cyan-500/40' : ''}`}
          >
            <div class="flex items-start justify-between gap-4">
              <h3 class={`text-white font-semibold text-lg ${project.url ? 'group-hover:text-cyan-400 transition-colors' : ''}`}>{project.name}</h3>
              {project.url
                ? <span class="text-slate-600 group-hover:text-slate-300 transition-colors text-xl">↗</span>
                : <span class="px-2 py-0.5 rounded text-xs font-mono bg-slate-800 text-slate-500 border border-slate-700">private</span>
              }
            </div>
            <div class="flex-1 flex flex-col gap-3">
              {project.description && <p class="text-slate-400 text-sm leading-relaxed">{project.description}</p>}
              {project.bullets && (
                <ul class="space-y-2">
                  {project.bullets.map((b: string) => (
                    <li class="flex gap-3 text-slate-400 text-sm leading-relaxed">
                      <span class="w-1.5 h-1.5 rounded-full bg-cyan-400 shrink-0 mt-1.5 shadow-[0_0_6px_rgba(34,211,238,0.9)]"></span>{b}
                    </li>
                  ))}
                </ul>
              )}
            </div>
            <div class="flex flex-wrap gap-2">
              {project.tech.map(t => (
                <span class="px-2.5 py-1 rounded-lg text-xs font-mono bg-slate-800 text-slate-400 border border-slate-700">{t}</span>
              ))}
            </div>
            {project.arch && (
              <button
                id="arch-open"
                class="self-start px-3 py-1.5 rounded-lg text-xs font-mono bg-cyan-600/20 text-cyan-400 border border-cyan-500/30 hover:bg-cyan-600/30 hover:text-cyan-300 transition-colors"
              >
                View architecture ↗
              </button>
            )}
          </Tag>
        );
      })}
    </div>
  </section>

  <!-- Contact -->
  <section class="no-print py-32 px-6 text-center border-t border-slate-800/50">
    <div data-animate>
      <p class="font-mono text-cyan-400 text-xs tracking-widest uppercase mb-3">Get in touch</p>
      <h2 class="text-4xl font-bold text-white mb-6">Let's work together</h2>
      <p class="text-slate-400 mb-10 max-w-md mx-auto">
        Open to new DevOps and Platform Engineering contracts. Reach out anytime.
      </p>
      <div class="flex gap-4 justify-center flex-wrap">
        <a href={`mailto:${hero.email}`}
          class="px-8 py-4 rounded-xl bg-cyan-600 hover:bg-cyan-500 text-white font-medium transition-colors text-lg">
          {hero.email}
        </a>
        <a href={hero.linkedin} target="_blank" rel="noopener noreferrer"
          class="px-8 py-4 rounded-xl border border-slate-700 hover:border-slate-500 text-slate-300 hover:text-white font-medium transition-colors text-lg">
          LinkedIn
        </a>
      </div>
    </div>
  </section>

  <footer class="no-print text-center text-slate-600 text-xs font-mono pb-8">
    Built with Astro · Self-hosted on homelab
  </footer>

  <!-- Architecture modal -->
  <div id="arch-modal" class="fixed inset-0 z-50 hidden items-center justify-center p-4 bg-black/80 backdrop-blur-sm">
    <div class="bg-slate-900 rounded-2xl border border-slate-700 max-w-4xl w-full p-8 relative max-h-[90vh] overflow-auto">
      <button id="arch-close" class="absolute top-4 right-4 text-slate-500 hover:text-white transition-colors text-2xl leading-none">×</button>
      <h3 class="text-white font-semibold text-xl mb-1">EKS Platform Architecture</h3>
      <p class="text-slate-500 text-xs font-mono mb-6">preview → dev → stg → prod · GitOps · zero-trust</p>
      <img src="/eks-arch.svg" alt="EKS Platform Architecture" class="w-full rounded-xl"/>
    </div>
  </div>

  <script>
    // Scroll progress bar
    const bar = document.getElementById('progress-bar');
    window.addEventListener('scroll', () => {
      const pct = window.scrollY / (document.body.scrollHeight - window.innerHeight) * 100;
      bar!.style.width = pct + '%';
    }, { passive: true });

    // Intersection observer for scroll animations
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('in-view');
          observer.unobserve(entry.target);
        }
      });
    }, { threshold: 0.15 });

    document.querySelectorAll('[data-animate]').forEach(el => observer.observe(el));

    // Architecture modal
    const archModal = document.getElementById('arch-modal');

    document.getElementById('arch-open')?.addEventListener('click', () => {
      archModal?.classList.remove('hidden');
      archModal?.classList.add('flex');
    });

    const closeModal = () => {
      archModal?.classList.add('hidden');
      archModal?.classList.remove('flex');
    };

    document.getElementById('arch-close')?.addEventListener('click', closeModal);
    archModal?.addEventListener('click', (e) => { if (e.target === archModal) closeModal(); });
    document.addEventListener('keydown', (e) => { if (e.key === 'Escape') closeModal(); });

    // Print: reveal scroll-animated elements that may not have been scrolled into view
    window.addEventListener('beforeprint', () => {
      document.querySelectorAll<HTMLElement>('[data-animate]').forEach(el => {
        el.classList.add('in-view');
      });
    });

    // PDF download with loading state
    document.getElementById('download-pdf')?.addEventListener('click', () => {
      const btn = document.getElementById('download-pdf') as HTMLButtonElement | null;
      const text = document.getElementById('pdf-btn-text');
      const icon = document.getElementById('pdf-icon');
      const spinner = document.getElementById('pdf-spinner');
      if (!btn || !text || !icon || !spinner) return;
      text.textContent = 'Preparing…';
      icon.classList.add('hidden');
      spinner.classList.remove('hidden');
      btn.disabled = true;
      setTimeout(() => {
        window.print();
        setTimeout(() => {
          text.textContent = 'Save as PDF';
          icon.classList.remove('hidden');
          spinner.classList.add('hidden');
          btn.disabled = false;
        }, 800);
      }, 350);
    });
  </script>
</Layout>
